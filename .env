# inSwing Environment Configuration
# Development environment with your MySQL credentials
# NEVER commit this file to version control

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Application Environment
ENVIRONMENT=development  # development, staging, production
APP_NAME=inSwing
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=true  # Set to false in production
API_V1_PREFIX=/api/v1

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# MySQL Database (Your Local MySQL 8.0 Installation)
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=inswing
DATABASE_USER=root
DATABASE_PASSWORD=Ganesh@15
DATABASE_URL=mysql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}

# Database Pool Settings
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# Database SSL (Production)
DATABASE_SSL_MODE=DISABLED  # Set to REQUIRED in production
DATABASE_SSL_CERT_PATH=/path/to/client-cert.pem
DATABASE_SSL_KEY_PATH=/path/to/client-key.pem
DATABASE_SSL_CA_PATH=/path/to/ca-cert.pem

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================

# Redis Connection (Docker Redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password123
REDIS_DB=0
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# Redis SSL (Production)
REDIS_SSL=false
REDIS_SSL_CERT_PATH=/path/to/redis-cert.pem
REDIS_SSL_KEY_PATH=/path/to/redis-key.pem

# Redis Pool Settings
REDIS_POOL_SIZE=50
REDIS_POOL_TIMEOUT=30
REDIS_SOCKET_TIMEOUT=30
REDIS_CONNECTION_TIMEOUT=30

# =============================================================================
# JWT & SECURITY CONFIGURATION
# =============================================================================

# JWT Settings
JWT_SECRET_KEY=your_super_secret_jwt_key_at_least_32_characters_long_change_this_now
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ISSUER=inSwing
JWT_AUDIENCE=inswing-users

# Password Security
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true

# =============================================================================
# OTP & SMS CONFIGURATION
# =============================================================================

# OTP Settings
OTP_EXPIRE_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_LENGTH=6
OTP_RESEND_TIMEOUT=60

# SMS Provider (Choose one)
SMS_PROVIDER=twilio  # twilio, msg91, 2factor, textlocal

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890
TWILIO_MESSAGING_SERVICE_SID=your_messaging_service_sid

# MSG91 Configuration (India)
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_SENDER_ID=INSPRT
MSG91_TEMPLATE_ID=your_template_id
MSG91_DLT_ID=your_dlt_id

# 2Factor Configuration (India)
FACTOR_API_KEY=your_2factor_api_key
FACTOR_SENDER_NAME=inSwing

# TextLocal Configuration (UK)
TEXTLOCAL_API_KEY=your_textlocal_api_key
TEXTLOCAL_SENDER=inSwing

# =============================================================================
# PUSH NOTIFICATIONS CONFIGURATION
# =============================================================================

# Firebase Cloud Messaging (FCM)
FCM_SERVER_KEY=your_fcm_server_key
FCM_SENDER_ID=your_fcm_sender_id
FCM_PROJECT_ID=your_firebase_project_id
FCM_SERVICE_ACCOUNT_PATH=/path/to/service-account.json

# Notification Settings
NOTIFICATION_BATCH_SIZE=100
NOTIFICATION_RETRY_ATTEMPTS=3
NOTIFICATION_RETRY_DELAY=60

# =============================================================================
# FILE STORAGE CONFIGURATION
# =============================================================================

# Storage Provider (Choose one)
STORAGE_PROVIDER=local  # local, aws_s3, digitalocean, gcp, azure

# Local Storage
LOCAL_STORAGE_PATH=/app/uploads
LOCAL_STORAGE_URL=http://localhost:8000/uploads

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=inswing-uploads
AWS_S3_ENDPOINT=https://s3.amazonaws.com
AWS_S3_CUSTOM_DOMAIN=cdn.inswing.com
AWS_S3_OBJECT_PARAMETERS={"CacheControl": "max-age=86400"}

# DigitalOcean Spaces Configuration
DO_SPACES_KEY=your_do_spaces_key
DO_SPACES_SECRET=your_do_spaces_secret
DO_SPACES_REGION=blr1
DO_SPACES_BUCKET=inswing-uploads
DO_SPACES_ENDPOINT=https://blr1.digitaloceanspaces.com
DO_SPACES_CDN_ENDPOINT=https://inswing.blr1.cdn.digitaloceanspaces.com

# File Upload Settings
MAX_FILE_SIZE_MB=5
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif,webp
ALLOWED_VIDEO_TYPES=mp4,mov,avi
IMAGE_COMPRESSION_QUALITY=85
THUMBNAIL_WIDTH=200
THUMBNAIL_HEIGHT=200

# =============================================================================
# WEBSOCKET CONFIGURATION
# =============================================================================

# WebSocket Settings
WEBSOCKET_MAX_CONNECTIONS=1000
WEBSOCKET_PING_INTERVAL=30
WEBSOCKET_PING_TIMEOUT=10
WEBSOCKET_MAX_MESSAGE_SIZE=1048576  # 1MB
WEBSOCKET_COMPRESSION=true

# Redis Pub/Sub Channels
REDIS_CHANNEL_MATCH_UPDATES=match:{match_id}:updates
REDIS_CHANNEL_MATCH_EVENTS=match:{match_id}:events
REDIS_CHANNEL_USER_NOTIFICATIONS=user:{user_id}:notifications
REDIS_CHANNEL_LEADERBOARD=leaderboard:{region}

# =============================================================================
# RATE LIMITING CONFIGURATION
# =============================================================================

# Rate Limiting Settings
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE_URL=redis://${REDIS_HOST}:${REDIS_PORT}/1
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_PER_DAY=10000

# Endpoint Specific Limits
RATE_LIMIT_AUTH_PER_MINUTE=5
RATE_LIMIT_MATCH_CREATE_PER_HOUR=10
RATE_LIMIT_BALL_RECORD_PER_MINUTE=60
RATE_LIMIT_OTP_REQUEST_PER_HOUR=3

# =============================================================================
# CORS & SECURITY CONFIGURATION
# =============================================================================

# CORS Settings
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,https://app.inswing.com
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-Requested-With
CORS_MAX_AGE=86400

# Security Headers
SECURITY_HEADERS_ENABLED=true
SECURITY_HEADERS_X_FRAME_OPTIONS=DENY
SECURITY_HEADERS_X_CONTENT_TYPE_OPTIONS=nosniff
SECURITY_HEADERS_X_XSS_PROTECTION=1; mode=block
SECURITY_HEADERS_STRICT_TRANSPORT_SECURITY=max-age=31536000; includeSubDomains
SECURITY_HEADERS_CONTENT_SECURITY_POLICY=default-src 'self'

# =============================================================================
# MONITORING & LOGGING CONFIGURATION
# =============================================================================

# Sentry Configuration (Error Tracking)
SENTRY_DSN=your_sentry_dsn_here
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILES_SAMPLE_RATE=1.0

# Logging Configuration
LOG_FORMAT=json  # json, text
LOG_FILE_PATH=/app/logs/inswing.log
LOG_FILE_MAX_SIZE=10485760  # 10MB
LOG_FILE_BACKUP_COUNT=5
LOG_ROTATION_WHEN=midnight

# Metrics & Monitoring
PROMETHEUS_METRICS_ENABLED=true
PROMETHEUS_METRICS_PORT=9090
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_ENDPOINT=/health

# =============================================================================
# BACKGROUND TASKS CONFIGURATION
# =============================================================================

# Celery Configuration (Background Tasks)
CELERY_BROKER_URL=redis://${REDIS_HOST}:${REDIS_PORT}/2
CELERY_RESULT_BACKEND=redis://${REDIS_HOST}:${REDIS_PORT}/3
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=UTC

# Background Task Settings
TASK_SEND_NOTIFICATIONS=true
TASK_UPDATE_LEADERBOARDS=true
TASK_CLEANUP_EXPIRED_SESSIONS=true
TASK_GENERATE_MATCH_REPORTS=true

# =============================================================================
# DEVELOPMENT & TESTING CONFIGURATION
# =============================================================================

# Development Settings
DEBUG_SQL_QUERIES=false
DEBUG_REQUEST_BODY=false
DEBUG_RESPONSE_BODY=false
DEBUG_WEBSOCKET_MESSAGES=false

# Testing Settings
TEST_DATABASE_NAME=inswing_test
TEST_DATABASE_URL=mysql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${TEST_DATABASE_NAME}
TEST_REDIS_DB=15
MOCK_SMS_ENABLED=false
MOCK_NOTIFICATIONS_ENABLED=false

# =============================================================================
# PRODUCTION SPECIFIC CONFIGURATION
# =============================================================================

# SSL/TLS Configuration
SSL_CERT_PATH=/etc/ssl/certs/inswing.crt
SSL_KEY_PATH=/etc/ssl/private/inswing.key
SSL_CA_PATH=/etc/ssl/certs/ca-certificates.crt

# Server Configuration
SERVER_NAME=api.inswing.com
SERVER_HOST=0.0.0.0
SERVER_PORT=443
SERVER_RELOAD=false
SERVER_WORKERS=8

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=/app/backups
BACKUP_S3_BUCKET=inswing-backups

# =============================================================================
# THIRD-PARTY INTEGRATIONS
# =============================================================================

# Email Configuration (Optional)
EMAIL_PROVIDER=smtp  # smtp, sendgrid, mailgun
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_TLS=true
SMTP_SSL=false

# Analytics Configuration (Optional)
GOOGLE_ANALYTICS_ID=GA_MEASUREMENT_ID
MIXPANEL_TOKEN=your_mixpanel_token
AMPLITUDE_API_KEY=your_amplitude_api_key

# Payment Gateway (Future)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key

# =============================================================================
# REGIONAL SETTINGS
# =============================================================================

# Default Region
DEFAULT_REGION=IN
DEFAULT_TIMEZONE=Asia/Kolkata
DEFAULT_LANGUAGE=en
DEFAULT_CURRENCY=INR

# Regional SMS Providers
SMS_PROVIDER_IN=msg91
SMS_PROVIDER_US=twilio
SMS_PROVIDER_UK=textlocal
SMS_PROVIDER_DEFAULT=twilio

# =============================================================================
# EMERGENCY & SUPPORT CONFIGURATION
# =============================================================================

# Support Contacts
SUPPORT_EMAIL=support@inswing.com
SUPPORT_PHONE=+91-XXXXXXXXXX
EMERGENCY_CONTACT=emergency@inswing.com

# Status Page
STATUS_PAGE_URL=https://status.inswing.com
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=We are currently under maintenance. We'll be back soon!